// Hashicorp clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace hashicorp {

    entity Service {
        id: string @unique
        name: string
        runtime: string
        region: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Deployment {
        id: string @unique
        serviceId: string
        version: string
        status: string
        deployedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Secret {
        id: string @unique
        name: string
        scope: string
        rotatedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity ApiProxy {
        id: string @unique
        name: string
        basePath: string
        target: string
        active: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Database {
        id: string @unique
        name: string
        engine: string
        region: string
        sizeGb: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Function {
        id: string @unique
        serviceId: string
        name: string
        memoryMb: integer
        timeoutMs: integer
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
